# For local development - single domain setup
NEXT_PUBLIC_WEBSITE_DOMAIN=localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# API Configuration - Using live server
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_TIMEOUT=50000
NEXT_PUBLIC_API_RETRY_ATTEMPTS=4

# WebSocket Configuration (for real-time updates)
NEXT_PUBLIC_WS_URL=http://localhost:4000

# File Upload Configuration
NEXT_PUBLIC_MAX_FILE_SIZE=10485760
NEXT_PUBLIC_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# Google Maps API (if needed)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here
